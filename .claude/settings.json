{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nix fmt --no-warn-dirty -- . < /dev/null",
            "statusMessage": "Formatting Nix files"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "auto"
  }
}
